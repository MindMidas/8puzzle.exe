#!/usr/bin/env bash
set -euo pipefail
ROOT="$(cd "$(dirname "$0")" && pwd)"
LOG_DIR="${ROOT}/.dev-logs"
PID_FILE="${LOG_DIR}/server.pid"
PORT="${EIGHTPUZZLE_PORT:-8001}"

usage() { echo "Usage: ./build [build|all|run|start|restart|stop|clean|typecheck|audit|help]"; }

install_deps() {
  [[ -d "${ROOT}/node_modules" ]] || (cd "${ROOT}" && npm ci --no-audit --no-fund)
}

stop_server() {
  [[ ! -f "${PID_FILE}" ]] || { kill "$(cat "${PID_FILE}")" 2>/dev/null || true; rm -f "${PID_FILE}"; }
  if command -v lsof >/dev/null 2>&1; then
    lsof -ti ":${PORT}" 2>/dev/null | xargs kill 2>/dev/null || true
  fi
}

run_server() {
  mkdir -p "${LOG_DIR}"
  nohup python3 -m src.server.app --host 127.0.0.1 --port "${PORT}" >"${LOG_DIR}/server.log" 2>&1 </dev/null &
  echo $! >"${PID_FILE}"
  echo "Eight Puzzle: http://127.0.0.1:${PORT}"
}

build_all() { install_deps; (cd "${ROOT}" && npm run build); }

case "${1:-all}" in
  build) build_all ;;
  all) build_all; stop_server; run_server ;;
  run|start) stop_server; run_server ;;
  restart) stop_server; build_all; run_server ;;
  stop) stop_server ;;
  clean)
    stop_server
    rm -rf "${ROOT}/src/frontend/dist" "${LOG_DIR}"
    find "${ROOT}/src" -type d -name __pycache__ -prune -exec rm -rf {} +
    find "${ROOT}/src" -type f -name '*.pyc' -delete
    ;;
  typecheck) install_deps; npm run typecheck ;;
  audit) install_deps; npm run typecheck; npm run audit ;;
  help|-h|--help) usage ;;
  *) usage; exit 1 ;;
esac
