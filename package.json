{
  "name": "eightpuzzle",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config src/frontend/vite.config.ts",
    "dev:server": "python3 -m src.server.app --port 8001",
    "start": "python3 -m src.server.app",
    "build": "npm run typecheck && vite build --config src/frontend/vite.config.ts",
    "typecheck": "tsc --noEmit",
    "audit": "npm audit --audit-level=moderate"
  },
  "dependencies": {
    "98.css": "0.1.21",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "vite": "8.0.16"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "6.0.2",
    "typescript": "^6.0.3"
  }
}
